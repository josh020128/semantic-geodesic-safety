<mujoco model="laptop_wine_scene">
    <compiler angle="degree" coordinate="local" texturedir="."/>

    <option gravity="0 0 -9.81"/>

    <visual>
        <rgba haze="1 1 1 1"/>
    </visual>

    <asset>
        <mesh name="laptop_mesh" file="data/assets/laptop/textured.obj" scale="20 20 20"/>
        <mesh name="wine_mesh" file="data/assets/wine/textured.obj" scale="20 20 20"/>

        <material name="laptop_mat" rgba="0.2 0.2 0.2 1"/>
        <material name="wine_mat" rgba="0.7 0.1 0.1 1"/>
    </asset>

    <worldbody>
        <light pos="0 -0.5 1.5" dir="0 0 -1" directional="true"/>

        <geom name="table" type="box" size="0.6 0.6 0.05" pos="0 0 0" rgba="1 1 1 1"/>

        <camera name="main_cam" pos="0 -1.2 0.6" zaxis="0 1 -0.35" fovy="45"/>

        <body name="laptop" pos="-0.12 0 0.08">
            <geom type="mesh" mesh="laptop_mesh" material="laptop_mat"/>
        </body>

        <body name="wine" pos="0.12 0 0.12">
            <geom type="mesh" mesh="wine_mesh" material="wine_mat"/>
        </body>
    </worldbody>
</mujoco>