<mujoco model="semantic_safety_tabletop_two_drills">
    <compiler angle="degree" coordinate="local" texturedir="."/>

    <option gravity="0 0 -9.81"/>

    <asset>
        <mesh name="drill_mesh" file="data/assets/power_drill/textured.obj" scale="1 1 1"/>
        <texture name="drill_tex" type="2d" file="data/assets/power_drill/texture_map.png"/>
        <material name="drill_mat" texture="drill_tex"/>
    </asset>

    <worldbody>
        <!-- shadow를 줄이고 perception을 안정화하려면 false 추천 -->
        <light pos="0 0 1.5" dir="0 0 -1" directional="true" castshadow="false"/>

        <geom
            name="table"
            type="box"
            size="0.5 0.5 0.05"
            pos="0 0 0"
            rgba="0.6 0.4 0.2 1"/>

        <camera
            name="main_cam"
            pos="0 -0.8 0.5"
            fovy="45"
            xyaxes="1 0 0 0 0.5 0.8"/>

        <!-- Left drill -->
        <body name="power_drill_left" pos="-0.24 0.00 0.10" euler="0 0 0">
            <geom
                name="power_drill_left_geom"
                type="mesh"
                mesh="drill_mesh"
                material="drill_mat"/>
        </body>

        <!-- Right drill: close enough to overlap risk fields, slightly rotated -->
        <body name="power_drill_right" pos="0.00 0.02 0.10" euler="0 0 12">
            <geom
                name="power_drill_right_geom"
                type="mesh"
                mesh="drill_mesh"
                material="drill_mat"/>
        </body>
    </worldbody>
</mujoco>